<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Default (dev/test/local-test): human-readable console output with the correlation/request
         ID (see RequestIdFilter) appended so a single request's log lines can be grep'd together. -->
    <springProfile name="!prod">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%thread] [requestId=%X{requestId:-none}] %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>
    </springProfile>

    <!-- prod: structured JSON logs (one JSON object per line) so a log aggregator can index
         fields directly instead of regex-parsing free text. Includes the same requestId MDC key.
         Never log full request/response bodies, tokens, or password hashes - AuthService/
         JwtService already avoid this; keep that invariant when adding new logging. -->
    <springProfile name="prod">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>requestId</includeMdcKeyName>
            </encoder>
        </appender>
    </springProfile>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
